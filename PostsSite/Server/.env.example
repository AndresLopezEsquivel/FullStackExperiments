# Copy to .env and fill in. Loaded via `node --env-file=.env` (see package.json).

# --- Local Postgres (default) ---
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postssite
# Leave empty locally; set to `require` to enable TLS (see below).
PGSSLMODE=

# --- Amazon RDS (when migrating) ---
# Point PGHOST at the RDS endpoint and require TLS:
# PGHOST=your-instance.abc123.us-east-1.rds.amazonaws.com
# PGUSER=postssite_app
# PGPASSWORD=...
# PGDATABASE=postssite
# PGSSLMODE=require

# --- Alternative: single connection string (overrides the PG* vars above) ---
# DATABASE_URL=postgres://user:password@host:5432/postssite
